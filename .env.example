# MercadoPago — Access Token (chave privada — nunca compartilhe!)
# Encontre em: mercadopago.com.br → Integrações → sua aplicação → Credenciais de produção
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# URL do frontend (onde o site está hospedado)
FRONTEND_URL=https://www.comicgeek.com.br

# URL do backend (onde este servidor está hospedado)
BACKEND_URL=https://api.comicgeek.com.br

# Porta do servidor (Railway/Render definem isso automaticamente)
PORT=3000

# PostgreSQL — banco de dados relacional (opcional; sem isso usa arquivos JSON locais)
# Formato: postgresql://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=postgresql://user:password@host:5432/dbname
