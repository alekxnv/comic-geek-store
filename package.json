{
  "name": "comic-geek-store",
  "version": "1.0.0",
  "description": "Comic Geek Store — Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testTimeout=15000 --forceExit",
    "test:watch": "jest --watch --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true,
    "setupFiles": [
      "./tests/setup.js"
    ],
    "globalTeardown": "./tests/teardown.js",
    "testTimeout": 20000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.0.15",
    "nodemailer": "^6.10.1",
    "pg": "^8.20.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
